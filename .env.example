# ESPN Fantasy Basketball
# Get your league ID from the URL: https://fantasy.espn.com/basketball/league?leagueId=XXXXXX
ESPN_LEAGUE_ID=your_league_id_here

# ESPN season year
ESPN_SEASON_ID=2025

# ESPN authentication cookies (see README for instructions on obtaining these)
# This cookie is found in your browser's Application > Cookies > fantasy.espn.com
ESPN_S2=your_espn_s2_cookie_here

# SWID cookie (looks like {XXXXXXXX-XXXX-XXXX-XXXX-XXXXXXXXXXXX})
# Also found in browser cookies at fantasy.espn.com
ESPN_SWID={your_swid_cookie_here}

# Supabase
# Get from: https://app.supabase.com → Project Settings → API
SUPABASE_URL=https://boolpdiyncuruuoumbzm.supabase.co

# Supabase public/anon key (safe to expose to frontend)
SUPABASE_ANON_KEY=your_anon_key_here

# Supabase service role key (keep secret - backend only)
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here

# Frontend environment variables (Vite exposes VITE_ prefixed vars to the browser)
# These are duplicated from the Supabase section for frontend use
VITE_SUPABASE_URL=https://boolpdiyncuruuoumbzm.supabase.co
VITE_SUPABASE_ANON_KEY=your_anon_key_here
